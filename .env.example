# ──────────────────────────────────────────────
# Golf Charity Subscription Platform — Unified .env.example
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Backend Configuration ─────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# Database (Local Postgres Docker string)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/golf_charity?schema=public"

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Payment Integration (Razorpay)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Email Setup (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM="Golf Charity Platform <no-reply@golfcharity.com>"

# ── Supabase Setup (Both Ends) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Frontend Configuration ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
