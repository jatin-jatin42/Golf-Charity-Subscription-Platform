# ── NestJS API (apps/api/.env) ────────────────────────
NODE_ENV=development
PORT=3001

# Database (Supabase PostgreSQL connection string)
# For local dev with Docker: postgresql://postgres:postgres@localhost:5432/golf_charity?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Email (Nodemailer / SendGrid SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM="Golf Charity Platform <no-reply@golfcharity.com>"

# File Upload (Supabase Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:3000
